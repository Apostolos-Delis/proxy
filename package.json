{
  "name": "proxy",
  "version": "0.1.0",
  "private": true,
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pnpm --filter @proxy/proxy dev",
    "dev:local": "node ./scripts/dev-local.mjs",
    "dev:proxy": "pnpm --filter @proxy/proxy dev",
    "dev:web": "pnpm --filter @proxy/web dev",
    "build:runtime": "tsc -b packages/schema packages/db apps/proxy && pnpm --filter @proxy/db copy:migrations",
    "cdk:synth": "pnpm --filter @proxy/infra-cdk synth",
    "cdk:diff": "pnpm --filter @proxy/infra-cdk cdk diff --all",
    "cdk:deploy": "pnpm --filter @proxy/infra-cdk cdk deploy --all",
    "start:prod:proxy": "pnpm --filter @proxy/proxy start:prod",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:console": "pnpm --filter @proxy/db console",
    "db:migrate": "pnpm --filter @proxy/db migrate",
    "db:runner": "pnpm --filter @proxy/db runner",
    "db:seed": "pnpm --filter @proxy/db seed",
    "build:web:aws": "VITE_PROXY_API_BASE= pnpm --filter @proxy/web build",
    "sync:web:aws": "node ./scripts/sync-web-assets.mjs",
    "sync:web:aws:dry-run": "PROXY_WEB_SYNC_DRY_RUN=true node ./scripts/sync-web-assets.mjs",
    "ops:migrate:aws": "PROXY_OPERATION=migrate node ./scripts/run-operations-task.mjs",
    "ops:seed:aws": "PROXY_OPERATION=seed node ./scripts/run-operations-task.mjs",
    "smoke": "pnpm --filter @proxy/proxy smoke",
    "smoke:deployed": "pnpm --filter @proxy/proxy smoke:deployed",
    "smoke:harnesses": "pnpm --filter @proxy/proxy smoke:harnesses",
    "test": "pnpm build:runtime && pnpm --filter @proxy/schema test && pnpm --filter @proxy/db test && pnpm --filter @proxy/proxy test && pnpm --filter @proxy/web test && pnpm --filter @proxy/infra-cdk test",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc -b",
    "build": "pnpm build:runtime && pnpm --filter @proxy/web build"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "oxlint": "^1.69.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1"
    }
  }
}
