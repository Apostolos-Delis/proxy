{
  "name": "prompt-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pnpm --filter @prompt-proxy/proxy dev",
    "dev:local": "node ./scripts/dev-local.mjs",
    "dev:proxy": "pnpm --filter @prompt-proxy/proxy dev",
    "dev:web": "pnpm --filter @prompt-proxy/web dev",
    "build:runtime": "tsc -b packages/schema packages/db apps/proxy && pnpm --filter @prompt-proxy/db copy:migrations",
    "cdk:synth": "pnpm --filter @prompt-proxy/infra-cdk synth",
    "cdk:diff": "pnpm --filter @prompt-proxy/infra-cdk cdk diff --all",
    "cdk:deploy": "pnpm --filter @prompt-proxy/infra-cdk cdk deploy --all",
    "start:prod:proxy": "pnpm --filter @prompt-proxy/proxy start:prod",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @prompt-proxy/db migrate",
    "db:seed": "pnpm --filter @prompt-proxy/db seed",
    "build:web:aws": "VITE_PROMPT_PROXY_API_BASE= pnpm --filter @prompt-proxy/web build",
    "sync:web:aws": "node ./scripts/sync-web-assets.mjs",
    "sync:web:aws:dry-run": "PROMPT_PROXY_WEB_SYNC_DRY_RUN=true node ./scripts/sync-web-assets.mjs",
    "ops:migrate:aws": "PROMPT_PROXY_OPERATION=migrate node ./scripts/run-operations-task.mjs",
    "ops:seed:aws": "PROMPT_PROXY_OPERATION=seed node ./scripts/run-operations-task.mjs",
    "smoke": "pnpm --filter @prompt-proxy/proxy smoke",
    "smoke:deployed": "pnpm --filter @prompt-proxy/proxy smoke:deployed",
    "smoke:harnesses": "pnpm --filter @prompt-proxy/proxy smoke:harnesses",
    "test": "pnpm build:runtime && pnpm --filter @prompt-proxy/schema test && pnpm --filter @prompt-proxy/db test && pnpm --filter @prompt-proxy/proxy test && pnpm --filter @prompt-proxy/web test && pnpm --filter @prompt-proxy/infra-cdk test",
    "typecheck": "tsc -b",
    "build": "pnpm build:runtime && pnpm --filter @prompt-proxy/web build"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
