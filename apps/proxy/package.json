{
  "name": "@prompt-proxy/proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/src/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx --env-file-if-exists=../../.env src/server.ts",
    "start:prod": "node --env-file-if-exists=../../.env dist/src/server.js",
    "smoke:harnesses": "node --env-file-if-exists=../../.env dist/scripts/smoke-harnesses.js",
    "smoke:deployed": "node --env-file-if-exists=../../.env dist/scripts/smoke-deployed.js",
    "smoke": "node --env-file-if-exists=../../.env dist/scripts/smoke-proxy.js",
    "schema:print": "tsx scripts/print-schema.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "profile:graphql": "tsx scripts/profile-graphql.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "0.4.5",
    "@fastify/cors": "^11.1.0",
    "@pothos/core": "^4.12.0",
    "@prompt-proxy/db": "workspace:*",
    "@prompt-proxy/schema": "workspace:*",
    "drizzle-orm": "0.45.2",
    "fastify": "^5.6.2",
    "graphql": "^16.14.2",
    "graphql-yoga": "^5.21.2",
    "pino": "^10.1.0",
    "ws": "^8.21.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
