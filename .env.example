PORT=8787
PROMPT_PROXY_TOKEN=dev-proxy-token
ALLOW_DEV_PROXY_TOKEN_FALLBACK=true
DEFAULT_ORGANIZATION_ID=local
ADMIN_CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173
ADMIN_DEV_LOGIN_ENABLED=true
ADMIN_DEV_LOGIN_EMAIL=local@example.com
ADMIN_DEV_LOGIN_PASSWORD=dev-password
ADMIN_SESSION_COOKIE_NAME=prompt_proxy_session
ADMIN_SESSION_TTL_SECONDS=28800
SEED_USER_ID=local-user
SEED_USER_EMAIL=local@example.com
SEED_USER_NAME=Local User

ADMIN_CONSOLE_URL=http://127.0.0.1:5173
RESEND_API_KEY=
EMAIL_FROM=Prompt Proxy <onboarding@resend.dev>

POSTGRES_PORT=55432
DATABASE_URL=postgres://prompt_proxy:prompt_proxy@localhost:55432/prompt_proxy

# Base64-encoded 32-byte key used to encrypt customer-supplied (BYOK) provider secrets at rest.
# Generate with: openssl rand -base64 32
PROVIDER_SECRET_ENCRYPTION_KEY=

OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_FAST_MODEL=gpt-5.4-mini
OPENAI_BALANCED_MODEL=gpt-5.4
OPENAI_HARD_MODEL=gpt-5.5
OPENAI_DEEP_MODEL=gpt-5.5-pro

ANTHROPIC_API_KEY=replace-me
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_FAST_MODEL=claude-haiku-4-5
ANTHROPIC_BALANCED_MODEL=claude-sonnet-4-5
ANTHROPIC_HARD_MODEL=claude-sonnet-4-5
ANTHROPIC_DEEP_MODEL=claude-opus-4-5

CLASSIFIER_PROVIDER=openai
CLASSIFIER_MODEL=gpt-5-nano-2025-08-07
CLASSIFIER_TIMEOUT_MS=10000
CLASSIFIER_MAX_ATTEMPTS=2
CLASSIFIER_ALLOW_REDACTED_EXCERPT=false

# USD per million tokens, overriding the built-in defaults per model.
# cacheReadCostPerMtok and cacheWriteCostPerMtok default to 10% and 125% of
# inputCostPerMtok when omitted. Organizations can override these live from
# the console Billing page without a restart.
# MODEL_COSTS_JSON={"claude-haiku-4-5":{"inputCostPerMtok":1,"outputCostPerMtok":5,"cacheReadCostPerMtok":0.1,"cacheWriteCostPerMtok":1.25}}

VITE_PROMPT_PROXY_API_BASE=http://127.0.0.1:8787

# Deployed smoke checks
# PROMPT_PROXY_DEPLOYED_BASE_URL=https://prompt-proxy.example.com
# PROMPT_PROXY_DEPLOYED_API_KEY=replace-me
# PROMPT_PROXY_DEPLOYED_ORGANIZATION_ID=local
# PROMPT_PROXY_DEPLOYED_ADMIN_EMAIL=local@example.com
# PROMPT_PROXY_DEPLOYED_ADMIN_PASSWORD=dev-password
# PROMPT_PROXY_DEPLOYED_ADMIN_COOKIE=prompt_proxy_session=replace-me
# PROMPT_PROXY_DEPLOYED_SKIP_ADMIN=false
