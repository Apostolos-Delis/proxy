PORT=8787
PROMPT_PROXY_TOKEN=dev-proxy-token
DEFAULT_ORGANIZATION_ID=local
ADMIN_CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

DATABASE_URL=postgres://prompt_proxy:prompt_proxy@localhost:5432/prompt_proxy

OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_FAST_MODEL=gpt-5.4-mini
OPENAI_BALANCED_MODEL=gpt-5.4
OPENAI_HARD_MODEL=gpt-5.5
OPENAI_DEEP_MODEL=gpt-5.5-pro

ANTHROPIC_API_KEY=replace-me
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_FAST_MODEL=claude-haiku-4-5
ANTHROPIC_BALANCED_MODEL=claude-sonnet-4-5
ANTHROPIC_HARD_MODEL=claude-sonnet-4-5
ANTHROPIC_DEEP_MODEL=claude-opus-4-5

CLASSIFIER_PROVIDER=openai
CLASSIFIER_MODEL=gpt-5-nano-2025-08-07
CLASSIFIER_TIMEOUT_MS=1500
CLASSIFIER_MAX_ATTEMPTS=2
CLASSIFIER_ALLOW_REDACTED_EXCERPT=false

VITE_PROMPT_PROXY_API_BASE=http://127.0.0.1:8787
VITE_PROMPT_PROXY_TOKEN=dev-proxy-token
