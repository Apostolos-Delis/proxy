{
  "$schema": "https://react.doctor/schema/config.json",
  "rules": {
    "react-doctor/no-array-index-as-key": "off",
    "react-doctor/async-await-in-loop": "off",
    "react-doctor/click-events-have-key-events": "off",
    "react-doctor/control-has-associated-label": "off",
    "react-doctor/interactive-supports-focus": "off",
    "react-doctor/js-combine-iterations": "off",
    "react-doctor/js-flatmap-filter": "off",
    "react-doctor/js-hoist-intl": "off",
    "react-doctor/js-min-max-loop": "off",
    "react-doctor/js-set-map-lookups": "off",
    "react-doctor/jsx-no-jsx-as-prop": "off",
    "react-doctor/no-autofocus": "off",
    "react-doctor/no-barrel-import": "off",
    "react-doctor/no-derived-useState": "off",
    "react-doctor/no-multi-comp": "off",
    "react-doctor/no-noninteractive-element-interactions": "off",
    "react-doctor/no-noninteractive-tabindex": "off",
    "react-doctor/no-redundant-roles": "off",
    "react-doctor/no-static-element-interactions": "off",
    "react-doctor/only-export-components": "off",
    "react-doctor/prefer-dynamic-import": "off",
    "react-doctor/prefer-html-dialog": "off",
    "react-doctor/prefer-module-scope-pure-function": "off",
    "react-doctor/prefer-tag-over-role": "off",
    "react-doctor/prefer-useReducer": "off",
    "react-doctor/query-mutation-missing-invalidation": "off",
    "react-doctor/rendering-hydration-mismatch-time": "off",
    "react-doctor/rerender-lazy-state-init": "off",
    "react-doctor/rerender-memo-with-default-value": "off",
    "react-doctor/role-supports-aria-props": "off"
  }
}
