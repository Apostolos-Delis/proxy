{
  "name": "@prompt-proxy/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/src/index.js",
    "./schema": "./dist/src/schema.js",
    "./migrations": "./dist/src/migrate-runner.js",
    "./seed": "./dist/src/seed.js",
    "./test": "./dist/src/test.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm copy:migrations",
    "copy:migrations": "mkdir -p dist/migrations && cp migrations/*.sql dist/migrations/",
    "console": "pnpm --filter @prompt-proxy/schema build && tsx --env-file-if-exists=../../.env src/console.ts",
    "migrate": "node --env-file-if-exists=../../.env dist/src/migrate.js",
    "runner": "pnpm --filter @prompt-proxy/schema build && tsx --env-file-if-exists=../../.env src/runner.ts",
    "seed": "node --env-file-if-exists=../../.env dist/src/seed.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "0.4.5",
    "@prompt-proxy/schema": "workspace:*",
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.7"
  },
  "devDependencies": {
    "drizzle-kit": "0.31.10",
    "tsx": "^4.21.0",
    "vitest": "^4.0.15"
  }
}
